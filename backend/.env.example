NODE_ENV=development
PORT=5000

# Database (MongoDB - matches Prisma schema and docker-compose)
DATABASE_URL=mongodb://docnear:docnear_dev_password@localhost:27017/docnear?authSource=admin

# JWT
JWT_SECRET=change-this-in-production-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-refresh-secret-minimum-32-chars

# Redis
REDIS_URL=redis://localhost:6379

# Frontend
FRONTEND_URL=http://localhost:3000

# AWS S3 (ap-south-1 Mumbai)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_MEDICAL=docnear-medical-files
S3_BUCKET_KYC=docnear-kyc-docs

# MSG91 OTP
MSG91_AUTH_KEY=
MSG91_TEMPLATE_OTP=
MSG91_SENDER_ID=DOCNR

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
