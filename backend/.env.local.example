# .env.local - Your local environment configuration
# Copy from .env.example and fill in your values
# This file is NOT committed to version control

# ===== DATABASE =====
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/booknear_db"

# ===== JWT CONFIGURATION =====
# Secret key for signing JWT tokens (minimum 32 characters recommended)
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long-for-security"
# Token expiration time (use valid time format like "7d", "24h", "3600s")
JWT_EXPIRATION="7d"

# ===== APPLICATION =====
# Node environment
NODE_ENV="development"
# Port to run the server
PORT=3001
# API prefix for all routes
API_PREFIX="api/v1"

# ===== CORS =====
# Frontend URL for CORS configuration
CORS_ORIGIN="http://localhost:3000"

# ===== EMAIL SERVICE (Optional) =====
# Gmail or any SMTP provider
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
# Use an app-specific password or regular password
SMTP_PASSWORD="your-app-specific-password"

# ===== PAYMENT GATEWAY (Optional) =====
# Stripe payment processing
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"

# ===== AWS S3 (Optional) =====
# For file uploads (salon images, etc.)
AWS_S3_BUCKET="booknear-bucket"
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
