// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & USER MODELS ====================

enum UserRole {
  CUSTOMER
  SALON_OWNER
  SALON_STAFF
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  phone             String   @unique
  passwordHash      String
  firstName         String
  lastName          String
  avatar            String?
  role              UserRole @default(CUSTOMER)
  status            UserStatus @default(ACTIVE)
  emailVerified     Boolean  @default(false)
  phoneVerified     Boolean  @default(false)
  
  // Relations
  customer          Customer?
  salonOwner        SalonOwner?
  salonStaff        SalonStaff?
  appointments      Appointment[]
  reviews           Review[]
  payments          Payment[]
  
  // Metadata
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastLoginAt       DateTime?
  deletedAt         DateTime?

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([status])
}

// ==================== CUSTOMER MODELS ====================

model Customer {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Profile
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  city              String?
  state             String?
  zipCode           String?
  country           String?
  
  // Preferences
  preferredSalons   SalonFavorite[]
  
  // Relations
  appointments      Appointment[]
  reviews           Review[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

// ==================== SALON MODELS ====================

enum SalonStatus {
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  SUSPENDED
  CLOSED
}

model SalonOwner {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Business Info
  businessName      String
  businessRegistration String?
  taxId             String?
  
  // Relations
  salons            Salon[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

model Salon {
  id                String   @id @default(cuid())
  ownerId           String
  owner             SalonOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  
  // Basic Info
  name              String
  description       String?
  phone             String
  email             String?
  website           String?
  status            SalonStatus @default(PENDING_APPROVAL)
  
  // Location
  address           String
  city              String
  state             String
  zipCode           String
  country           String   @default("IN")
  latitude          Float?
  longitude         Float?
  
  // Business Hours
  openingTime       String   @default("09:00")
  closingTime       String   @default("18:00")
  daysOpen          String   @default("Monday,Tuesday,Wednesday,Thursday,Friday,Saturday")
  
  // Media
  logo              String?
  banner            String?
  images            String[]
  
  // Relations
  services          Service[]
  staff             SalonStaff[]
  appointments      Appointment[]
  reviews           Review[]
  favorites         SalonFavorite[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@index([ownerId])
  @@index([city])
  @@index([status])
  @@fulltext([name, city])
}

model SalonStaff {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  salonId           String
  salon             Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  
  // Role & Permissions
  role              String   @default("staff") // "staff", "manager", "specialist"
  specialties       String[] // e.g., ["haircut", "coloring", "massage"]
  
  // Availability
  isAvailable       Boolean  @default(true)
  
  // Relations
  appointments      Appointment[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, salonId])
  @@index([salonId])
  @@index([userId])
}

model SalonFavorite {
  id                String   @id @default(cuid())
  customerId        String
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salonId           String
  salon             Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  
  createdAt         DateTime @default(now())

  @@unique([customerId, salonId])
  @@index([customerId])
  @@index([salonId])
}

// ==================== SERVICE MODELS ====================

enum ServiceStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model Service {
  id                String   @id @default(cuid())
  salonId           String
  salon             Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  
  // Service Details
  name              String
  description       String?
  category          String   // e.g., "haircut", "massage", "spa"
  duration          Int      // in minutes
  price             Float
  discountPrice     Float?
  status            ServiceStatus @default(ACTIVE)
  
  // Relations
  appointments      Appointment[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([salonId])
  @@index([category])
}

// ==================== APPOINTMENT MODELS ====================

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum AppointmentPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Appointment {
  id                String   @id @default(cuid())
  customerId        String
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salonId           String
  salon             Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  serviceId         String
  service           Service  @relation(fields: [serviceId], references: [id])
  staffId           String?
  staff             SalonStaff? @relation(fields: [staffId], references: [id])
  
  // Appointment Details
  appointmentDate   DateTime
  startTime         String   // HH:mm format
  endTime           String   // HH:mm format
  status            AppointmentStatus @default(PENDING)
  notes             String?
  
  // Payment
  totalAmount       Float
  paymentStatus     AppointmentPaymentStatus @default(PENDING)
  payment           Payment?
  
  // Relations
  review            Review?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  cancelledAt       DateTime?
  rescheduleFrom    String?  // ID of previous appointment if rescheduled

  @@index([customerId])
  @@index([salonId])
  @@index([serviceId])
  @@index([staffId])
  @@index([status])
  @@index([appointmentDate])
}

// ==================== PAYMENT MODELS ====================

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  UPI
  WALLET
  BANK_TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
  CANCELLED
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointmentId     String   @unique
  appointment       Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  
  // Payment Details
  amount            Float
  currency          String   @default("INR")
  method            PaymentMethod
  transactionId     String?  @unique
  status            PaymentStatus @default(PENDING)
  
  // Payment Gateway Response
  gatewayResponse   String?  // JSON string of gateway response
  
  // Refund
  isRefunded        Boolean  @default(false)
  refundAmount      Float?
  refundedAt        DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([appointmentId])
  @@index([status])
  @@index([transactionId])
}

// ==================== REVIEW MODELS ====================

model Review {
  id                String   @id @default(cuid())
  customerId        String
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salonId           String
  salon             Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  appointmentId     String
  appointment       Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Review Content
  rating            Int      // 1-5
  title             String?
  comment           String?
  
  // Verification
  isVerified        Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([appointmentId])
  @@index([salonId])
  @@index([customerId])
  @@index([rating])
}

// ==================== NOTIFICATION MODELS ====================

enum NotificationType {
  APPOINTMENT_CONFIRMED
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELLED
  REVIEW_REQUEST
  PROMOTION
  SYSTEM
}

model Notification {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type              NotificationType
  title             String
  message           String
  data              String?  // JSON string of additional data
  
  isRead            Boolean  @default(false)
  readAt            DateTime?
  
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
