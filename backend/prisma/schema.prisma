// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


// ═════════════════════════════════════════════════════════════════════════════
// ENUMS
// ═════════════════════════════════════════════════════════════════════════════

enum UserRole {
  patient
  doctor
  admin
  super_admin
}

enum KycStatus {
  pending
  under_review
  approved
  rejected
}

enum AppointmentStatus {
  scheduled
  confirmed
  in_progress
  completed
  cancelled
  no_show
}

enum AppointmentType {
  online
  offline
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum PaymentMode {
  online
  at_clinic
}

enum SubscriptionPlan {
  free
  basic
  featured
}

enum FeedPostType {
  case_study
  medical_news
  health_tip
  question
  announcement
}

enum NotificationType {
  appointment_booked
  appointment_cancelled
  appointment_reminder
  kyc_approved
  kyc_rejected
  new_review
  prescription_ready
}

enum Gender {
  male
  female
  other
  prefer_not_to_say
}

enum ReportType {
  lab_report
  imaging
  prescription
  discharge_summary
  other
}

// ═════════════════════════════════════════════════════════════════════════════
// EMBEDDED TYPES (used inside documents)
// ═════════════════════════════════════════════════════════════════════════════

type GeoLocation {
  type        String   @default("Point")
  coordinates Float[]  // [longitude, latitude]
}

type TimeSlot {
  startTime   String   // "09:00"
  endTime     String   // "09:30"
  isBooked    Boolean  @default(false)
}

type DaySchedule {
  day         String   // "monday", "tuesday", etc.
  isAvailable Boolean  @default(true)
  slots       TimeSlot[]
}

type FamilyMember {
  name        String
  relation    String
  dateOfBirth DateTime?
  gender      Gender?
  bloodGroup  String?
}

type Medicine {
  name        String
  dosage      String   // "500mg"
  frequency   String   // "twice a day"
  duration    String   // "7 days"
  instructions String?
}

// ═════════════════════════════════════════════════════════════════════════════
// USERS — Base user model (all 3 roles)
// ═════════════════════════════════════════════════════════════════════════════

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  mobile       String   @unique
  email        String?  @unique
  role         UserRole @default(patient)
  name         String?
  avatar       String?  // S3 URL
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false) // mobile verified
  fcmToken     String?  // Firebase push token
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  doctorProfile   DoctorProfile?
  patientProfile  PatientProfile?
  appointments    Appointment[]  @relation("PatientAppointments")
  notifications   Notification[]
  feedPosts       FeedPost[]
  reviews         Review[]       @relation("PatientReviews")

  @@map("users")
}

// ═════════════════════════════════════════════════════════════════════════════
// DOCTOR PROFILE
// ═════════════════════════════════════════════════════════════════════════════

model DoctorProfile {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  userId            String           @unique @db.ObjectId
  user              User             @relation(fields: [userId], references: [id])

  // Professional info
  registrationNumber String          @unique
  qualifications     String[]        // ["MBBS", "MD"]
  specializations    String[]        // ["Cardiology", "General Medicine"]
  experience         Int             @default(0) // years
  languages          String[]        @default(["Hindi", "English"])
  bio                String?

  // Clinic info
  clinicName         String?
  clinicAddress      String?
  city               String
  state              String          @default("Madhya Pradesh")
  pincode            String
  location           GeoLocation?    // for geospatial queries

  // Availability
  consultationFee    Int             @default(0) // in rupees
  schedule           DaySchedule[]   // weekly schedule with slots
  slotDuration       Int             @default(30) // minutes

  // Verification & subscription
  kycStatus          KycStatus       @default(pending)
  isListed           Boolean         @default(false) // visible to patients after KYC
  subscriptionPlan   SubscriptionPlan @default(free)
  subscriptionEndsAt DateTime?

  // Stats (denormalized for performance)
  totalAppointments  Int             @default(0)
  totalReviews       Int             @default(0)
  averageRating      Float           @default(0)

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // Relations
  appointments       Appointment[]   @relation("DoctorAppointments")
  kycSubmission      KycSubmission?
  prescriptions      Prescription[]
  reviews            Review[]        @relation("DoctorReviews")

  @@map("doctor_profiles")
}

// ═════════════════════════════════════════════════════════════════════════════
// PATIENT PROFILE
// ═════════════════════════════════════════════════════════════════════════════

model PatientProfile {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  userId        String        @unique @db.ObjectId
  user          User          @relation(fields: [userId], references: [id])

  dateOfBirth   DateTime?
  gender        Gender?
  bloodGroup    String?
  allergies     String[]
  chronicConditions String[]
  familyMembers FamilyMember[]
  address       String?
  city          String?
  pincode       String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("patient_profiles")
}

// ═════════════════════════════════════════════════════════════════════════════
// APPOINTMENTS
// ═════════════════════════════════════════════════════════════════════════════

model Appointment {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId

  patientId       String            @db.ObjectId
  patient         User              @relation("PatientAppointments", fields: [patientId], references: [id])

  doctorProfileId String            @db.ObjectId
  doctor          DoctorProfile     @relation("DoctorAppointments", fields: [doctorProfileId], references: [id])

  // For offline/walk-in patients (no account needed)
  offlinePatientName   String?
  offlinePatientMobile String?

  appointmentDate String            // "2025-03-15" ISO date string
  slotTime        String            // "10:30"
  type            AppointmentType   @default(offline)
  status          AppointmentStatus @default(scheduled)

  // Payment
  paymentMode     PaymentMode       @default(at_clinic)
  paymentStatus   PaymentStatus     @default(pending)
  paymentId       String?           // Razorpay payment ID
  amount          Int               @default(0) // in rupees

  // Clinical notes
  symptoms        String?
  notes           String?           // doctor's notes
  followUpDate    DateTime?

  // Token number for queue management
  tokenNumber     Int?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  prescription    Prescription?
  reports         MedicalReport[]

  @@map("appointments")
}

// ═════════════════════════════════════════════════════════════════════════════
// PRESCRIPTIONS
// ═════════════════════════════════════════════════════════════════════════════

model Prescription {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  appointmentId   String        @unique @db.ObjectId
  appointment     Appointment   @relation(fields: [appointmentId], references: [id])

  doctorProfileId String        @db.ObjectId
  doctor          DoctorProfile @relation(fields: [doctorProfileId], references: [id])

  diagnosis       String?
  medicines       Medicine[]    // embedded array
  advice          String?
  followUpDays    Int?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("prescriptions")
}

// ═════════════════════════════════════════════════════════════════════════════
// MEDICAL REPORTS
// ═════════════════════════════════════════════════════════════════════════════

model MedicalReport {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  patientId       String        @db.ObjectId
  appointmentId   String?       @db.ObjectId
  appointment     Appointment?  @relation(fields: [appointmentId], references: [id])

  type            ReportType    @default(lab_report)
  title           String
  fileUrl         String        // S3 presigned URL (private bucket)
  fileKey         String        // S3 key for deletion
  fileSize        Int?          // bytes
  mimeType        String?

  uploadedAt      DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("medical_reports")
}

// ═════════════════════════════════════════════════════════════════════════════
// KYC SUBMISSIONS
// ═════════════════════════════════════════════════════════════════════════════

model KycSubmission {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  doctorProfileId String        @unique @db.ObjectId
  doctor          DoctorProfile @relation(fields: [doctorProfileId], references: [id])

  // Documents (S3 keys — admin-only private bucket)
  medicalLicenseKey    String?
  degreeCertificateKey String?
  govtIdKey            String?
  selfieKey            String?

  status          KycStatus     @default(pending)
  reviewedBy      String?       // admin userId
  reviewedAt      DateTime?
  rejectionReason String?
  adminNotes      String?

  submittedAt     DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("kyc_submissions")
}

// ═════════════════════════════════════════════════════════════════════════════
// REVIEWS
// ═════════════════════════════════════════════════════════════════════════════

model Review {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  doctorProfileId String        @db.ObjectId
  doctor          DoctorProfile @relation("DoctorReviews", fields: [doctorProfileId], references: [id])

  patientId       String        @db.ObjectId
  patient         User          @relation("PatientReviews", fields: [patientId], references: [id])

  rating          Int           // 1–5
  comment         String?
  isVerified      Boolean       @default(false) // patient had an actual appointment
  isHidden        Boolean       @default(false) // admin can hide

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("reviews")
}

// ═════════════════════════════════════════════════════════════════════════════
// FEED POSTS (Doctor social feed)
// ═════════════════════════════════════════════════════════════════════════════

model FeedPost {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  authorId        String        @db.ObjectId
  author          User          @relation(fields: [authorId], references: [id])

  type            FeedPostType  @default(health_tip)
  title           String?
  content         String
  imageUrl        String?       // optional image
  tags            String[]      // specialization tags

  likesCount      Int           @default(0)
  commentsCount   Int           @default(0)
  isHidden        Boolean       @default(false) // admin moderation

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  comments        FeedComment[]

  @@map("feed_posts")
}

model FeedComment {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  postId      String    @db.ObjectId
  post        FeedPost  @relation(fields: [postId], references: [id])
  authorId    String    @db.ObjectId
  content     String
  isHidden    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@map("feed_comments")
}

// ═════════════════════════════════════════════════════════════════════════════
// NOTIFICATIONS
// ═════════════════════════════════════════════════════════════════════════════

model Notification {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  userId      String           @db.ObjectId
  user        User             @relation(fields: [userId], references: [id])

  type        NotificationType
  title       String
  body        String
  data        Json?            // extra metadata (appointmentId, etc.)
  isRead      Boolean          @default(false)

  createdAt   DateTime         @default(now())

  @@map("notifications")
}

// ═════════════════════════════════════════════════════════════════════════════
// CITIES (Supported service areas)
// ═════════════════════════════════════════════════════════════════════════════

model City {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String    @unique
  state       String
  pinCodes    String[]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@map("cities")
}
