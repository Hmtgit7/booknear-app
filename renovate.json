{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separatePatchReleases",
    "group:monorepos",
    "group:recommended",
    "helpers:pinGitHubActionDigests"
  ],

  "baseBranches": ["develop"],
  "targetBranch": "develop",
  "defaultBranch": "develop",

  "timezone": "Asia/Kolkata",
  "schedule": ["after 12am and before 5am on Monday"],

  "dependencyDashboard": true,
  "dependencyDashboardTitle": "🔄 DocNear — Renovate Dependency Dashboard",
  "dependencyDashboardAutoclose": true,

  "labels": ["dependencies"],
  "assignees": ["@hemant"],
  "reviewers": ["@hemant"],

  "commitMessagePrefix": "chore(deps):",
  "commitMessageAction": "update",
  "semanticCommits": "enabled",

  "prHourlyLimit": 2,
  "prConcurrentLimit": 8,
  "branchConcurrentLimit": 8,

  "automerge": false,
  "automergeType": "pr",
  "automergeStrategy": "squash",

  "ignorePaths": ["**/node_modules/**", "**/.next/**", "**/dist/**", "**/build/**"],

  "packageRules": [
    {
      "description": "Label backend PRs",
      "matchFileNames": ["backend/**"],
      "labels": ["dependencies", "backend"],
      "commitMessagePrefix": "chore(deps/backend):"
    },

    {
      "description": "Label frontend PRs",
      "matchFileNames": ["frontend/**"],
      "labels": ["dependencies", "frontend"],
      "commitMessagePrefix": "chore(deps/frontend):"
    },

    {
      "description": "Label shared packages PRs",
      "matchFileNames": ["frontend/packages/**"],
      "labels": ["dependencies", "shared-packages"],
      "commitMessagePrefix": "chore(deps/packages):"
    },

    {
      "description": "Group all NestJS packages into one PR",
      "matchPackagePrefixes": ["@nestjs/"],
      "groupName": "NestJS packages",
      "groupSlug": "nestjs",
      "labels": ["dependencies", "backend", "nestjs"]
    },

    {
      "description": "Group all Next.js + React packages into one PR",
      "matchPackageNames": ["next", "react", "react-dom"],
      "matchPackagePrefixes": ["@next/"],
      "groupName": "Next.js + React",
      "groupSlug": "nextjs-react",
      "labels": ["dependencies", "frontend", "nextjs"]
    },

    {
      "description": "Group all ShadCN + Radix UI into one PR",
      "matchPackagePrefixes": ["@radix-ui/", "@shadcn/"],
      "matchPackageNames": ["class-variance-authority", "clsx", "tailwind-merge"],
      "groupName": "ShadCN + Radix UI",
      "groupSlug": "shadcn-radix",
      "labels": ["dependencies", "frontend", "ui"]
    },

    {
      "description": "Group all Zustand + RxDB packages",
      "matchPackageNames": ["zustand", "rxdb", "rxjs"],
      "matchPackagePrefixes": ["rxdb/"],
      "groupName": "State + RxDB",
      "groupSlug": "state-rxdb",
      "labels": ["dependencies", "frontend", "state"]
    },

    {
      "description": "Group all Tailwind packages into one PR",
      "matchPackageNames": ["tailwindcss", "postcss", "autoprefixer"],
      "matchPackagePrefixes": ["@tailwindcss/", "tailwindcss-"],
      "groupName": "Tailwind CSS",
      "groupSlug": "tailwind",
      "labels": ["dependencies", "frontend"]
    },

    {
      "description": "Group TypeScript + type definitions",
      "matchPackageNames": ["typescript"],
      "matchPackagePrefixes": ["@types/"],
      "groupName": "TypeScript + @types",
      "groupSlug": "typescript-types",
      "labels": ["dependencies", "typescript"]
    },

    {
      "description": "Group ESLint ecosystem into one PR",
      "matchPackageNames": ["eslint", "prettier"],
      "matchPackagePrefixes": ["eslint-", "@eslint/", "eslint-config-", "eslint-plugin-"],
      "groupName": "ESLint + Prettier",
      "groupSlug": "eslint-prettier",
      "labels": ["dependencies", "tooling"]
    },

    {
      "description": "Group Prisma packages into one PR",
      "matchPackageNames": ["prisma", "@prisma/client"],
      "groupName": "Prisma",
      "groupSlug": "prisma",
      "labels": ["dependencies", "backend", "database"]
    },

    {
      "description": "Group Jest + testing libraries into one PR",
      "matchPackageNames": ["jest", "ts-jest", "vitest"],
      "matchPackagePrefixes": ["@jest/", "@vitest/", "@testing-library/", "jest-"],
      "groupName": "Testing libraries",
      "groupSlug": "testing",
      "labels": ["dependencies", "testing"]
    },

    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions",
      "labels": ["dependencies", "ci-cd"]
    },

    {
      "description": "Automerge safe patch + digest updates for tooling",
      "matchUpdateTypes": ["patch", "digest"],
      "matchDepTypes": ["devDependencies"],
      "matchPackagePrefixes": ["@types/", "eslint-", "prettier"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },

    {
      "description": "Automerge GitHub Actions patch updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "platformAutomerge": true
    },

    {
      "description": "Pin Node.js versions — do not auto-update",
      "matchPackageNames": ["node"],
      "matchManagers": ["nodenv", "nvm"],
      "enabled": false
    },

    {
      "description": "Security-sensitive packages — never automerge, require review",
      "matchPackageNames": [
        "passport",
        "passport-jwt",
        "@nestjs/passport",
        "@nestjs/jwt",
        "bcrypt",
        "jsonwebtoken",
        "helmet",
        "express-rate-limit",
        "razorpay",
        "prisma",
        "@prisma/client"
      ],
      "automerge": false,
      "labels": ["dependencies", "security-review"],
      "reviewers": ["@hemant"]
    },

    {
      "description": "Major version updates — never automerge, extra label",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major-update", "needs-review"],
      "stabilityDays": 7
    },

    {
      "description": "Hold minor updates for 3 days (let bugs surface in community)",
      "matchUpdateTypes": ["minor"],
      "stabilityDays": 3
    },

    {
      "description": "Patch updates go immediately",
      "matchUpdateTypes": ["patch"],
      "stabilityDays": 1
    }
  ],

  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "vulnerability"],
    "automerge": false,
    "schedule": ["at any time"]
  },

  "osvVulnerabilityAlerts": true,

  "postUpdateOptions": ["pnpmDedupe"],

  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on the first day of the month"],
    "commitMessageAction": "refresh lockfile",
    "labels": ["dependencies", "lockfile-maintenance"]
  }
}
